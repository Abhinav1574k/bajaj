# ──────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# Server port (Render sets this automatically — leave as 5000 for local dev)
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/support-tickets?retryWrites=true&w=majority

# Environment (development | production)
NODE_ENV=production

# Your Vercel frontend URL — paste it here (no trailing slash)
# Example: https://my-support-app.vercel.app
CLIENT_URL=https://YOUR_FRONTEND.vercel.app
